{
  "name": "edumarket-backend",
  "version": "1.1.0",
  "description": "EduMarket - P2P student micro-task marketplace backend (Telegram Mini App)",
  "main": "server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "npx prisma db push --accept-data-loss",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force",
    "db:seed": "node prisma/seed.js",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:patch": "standard-version --release-as patch",
    "release:major": "standard-version --release-as major"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/s3-request-presigner": "^3.1063.0",
    "@prisma/client": "^5.14.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.0",
    "file-type": "^22.0.1",
    "firebase-admin": "^10.3.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "rate-limit-redis": "^5.0.0",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.1",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0",
    "standard-version": "^9.5.0"
  },
  "nodemonConfig": {
    "ignore": [
      "logs/*",
      "prisma/migrations/*"
    ],
    "delay": 500
  }
}
