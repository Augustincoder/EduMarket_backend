// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// в”Ђв”Ђв”Ђ ENUMS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  PREVIEW_PENDING
  IN_REVIEW
  COMPLETED
  CANCELED
  DISPUTED
}

enum TaskCategory {
  KONSPEKT     // Lecture notes
  SLAYD        // Slides / presentations
  TARJIMA      // Translation
  KURS_ISHI    // Course work / term paper
  REFERAT      // Essay / referat
  LABORATORIYA // Lab report
  BOSHQA       // Other
}

enum UserRole {
  USER
  ADMIN
}

enum TransactionType {
  VIP_PURCHASE
  ESCROW_HOLD
  ESCROW_RELEASE
  ESCROW_REFUND
  COMMISSION
  REFERRAL_BONUS
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_FOR_CLIENT
  RESOLVED_FOR_FREELANCER
  CLOSED
}

enum ReportType {
  TASK_QUALITY
  DEADLINE_BREACH
  COMMUNICATION
  FRAUD
  INAPPROPRIATE
  FAKE_PROFILE
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum VerificationStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

// в”Ђв”Ђв”Ђ USER в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model User {
  id String @id @default(cuid())
  telegramId  BigInt   @unique @map("telegram_id")
  username    String?  @unique @map("username")
  fullname    String   @map("fullname")
  avatarUrl   String?  @map("avatar_url")
  role        UserRole @default(USER)

  // в”Ђв”Ђ Rating (computed from sum/count to avoid float drift) в”Ђв”Ђ
  ratingSum   Int @default(0) @map("rating_sum")
  ratingCount Int @default(0) @map("rating_count")

  // в”Ђв”Ђ VIP / Promoted Profile в”Ђв”Ђ
  isVip       Boolean   @default(false) @map("is_vip")
  vipExpiresAt DateTime? @map("vip_expires_at")

  // в”Ђв”Ђ Profile (Phase 14) в”Ђв”Ђ
  bio          String?  @db.Text
  skills       String[] @default([])
  portfolioIds String[] @default([]) @map("portfolio_ids") // Telegram file_ids
  badge        String   @default("YANGI") // YANGI|ISHONCHLI|PRO|ELITE

  // ── Onboarding & Freelancer (v2.0) ──
  isOnboardingComplete Boolean  @default(false) @map("is_onboarding_complete")
  isFreelancer         Boolean  @default(false) @map("is_freelancer")
  freelancerCategories String[] @default([])    @map("freelancer_categories")
  freelancerBio        String?  @db.Text        @map("freelancer_bio")
  freelancerExperience Int?     @map("freelancer_experience")
  
  region               String?
  universityId         Int?     @map("university_id")
  university           String?
  faculty              String?
  studyYear            Int?     @map("study_year")
  studentCardFileId    String?  @map("student_card_file_id")
  isVerifiedStudent    Boolean  @default(false) @map("is_verified_student")
  verificationStatus   VerificationStatus @default(REJECTED) @map("verification_status") // REJECTED here acts as 'NOT_SUBMITTED' initially if status is PENDING/APPROVED

  // ── Analytics (Phase 14) ──
  completionRate Float?   @map("completion_rate") // hisoblangan: scheduler
  avgResponseHrs Float?   @map("avg_response_hrs")

  // ── Gamification & Retention (Phase 5) ──
  streakCount    Int       @default(0) @map("streak_count")
  lastLoginDate  DateTime? @map("last_login_date")
  xp             Int       @default(0) @map("xp")
  achievements   Json      @default("[]") @map("achievements")

  // ── Referral (Phase 14 & Phase 5) ──
  referralCode   String?  @unique @map("referral_code")
  referredBy     String?  @map("referred_by")
  referralEarned Float    @default(0) @map("referral_earned")

  // ── Notification preferences (Phase 14) ──
  notifPrefs Json @default("{}") @map("notif_prefs")
  pushToken  String? @map("push_token")
  // { "newBid": true, "chatMessage": true, "deadlineReminder": true,
  //   "taskAssigned": true, "reviewReminder": true }

  // ── Anti-fraud ──
  lastIpAddress String?  @map("last_ip_address")
  deviceHash    String?  @map("device_hash")
  isBanned      Boolean  @default(false) @map("is_banned")
  banReason     String?  @map("ban_reason")

  // ── Soft delete ──
  deletedAt DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  clientTasks     Task[]    @relation("ClientTasks")
  freelancerTasks Task[]    @relation("FreelancerTasks")
  bids            Bid[]
  sentMessages    ChatMessage[] @relation("SentMessages")
  reviewsGiven    Review[]  @relation("ReviewsGiven")
  reviewsReceived Review[]  @relation("ReviewsReceived")
  vipPayments     VipPayment[]
  transactions    TransactionLog[]
  savedTasks      SavedTask[]
  gigs            Gig[]
  portfolioItems  PortfolioItem[]
  reportsSubmitted Report[] @relation("ReporterRelation")
  reportsReceived  Report[] @relation("ReportedRelation")
  verificationRequests VerificationRequest[]
  notifications    Notification[] @relation("UserNotifications")
  taskFlags        TaskFlag[]

  @@index([isBanned])
  @@index([isVip])
  @@index([deletedAt])
  @@map("users")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model Task {
  id String @id @default(cuid())
  clientId     String          @map("client_id")
  freelancerId String?         @map("freelancer_id")

  category     TaskCategory
  title        String       @db.VarChar(200)
  description  String       @db.Text
  priceMin     Int          @map("price_min")
  priceMax     Int          @map("price_max")
  agreedPrice  Int?         @map("agreed_price")

  deadline     DateTime     @map("deadline")
  status       TaskStatus   @default(OPEN)

  // ── File attachments (Telegram file_id strings) ──
  attachmentFileIds String[] @default([]) @map("attachment_file_ids")

  // ── Urgency (Phase 14) ──
  isUrgent Boolean @default(false) @map("is_urgent")
  rushFee  Int     @default(0)     @map("rush_fee")
  promotedUntil DateTime? @map("promoted_until")

  // ── State transition timestamps (for anti-fraud 24h check) ──
  assignedAt   DateTime? @map("assigned_at")
  inProgressAt DateTime? @map("in_progress_at")
  inReviewAt   DateTime? @map("in_review_at")
  completedAt  DateTime? @map("completed_at")
  canceledAt   DateTime? @map("canceled_at")

  // ── Soft delete ──
  deletedAt DateTime? @map("deleted_at")

  // Phase 8: Peer Quality Shield
  flagCount    Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  client     User         @relation("ClientTasks", fields: [clientId], references: [id])
  freelancer User?        @relation("FreelancerTasks", fields: [freelancerId], references: [id])
  bids       Bid[]
  chat       ChatMessage[]
  reviews    Review[]
  dispute    Dispute?
  savedBy    SavedTask[]
  reports    Report[]
  delivery   WorkDelivery?
  flags      TaskFlag[]

  // Phase 14 / Phase 4: Collaborative Task Rooms
  milestones      TaskMilestone[]

  @@index([status])
  @@index([clientId])
  @@index([freelancerId])
  @@index([category])
  @@index([deadline])
  @@index([deletedAt])
  @@index([isUrgent])
  @@map("tasks")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model Bid {
  id String @id @default(cuid())
  taskId       String     @map("task_id")
  freelancerId String     @map("freelancer_id")

  message       String  @db.Text
  proposedPrice Int     @map("proposed_price")
  isAccepted    Boolean @default(false) @map("is_accepted")

  // ── Counter-offer (Phase 14) ──
  counterPrice   Int?      @map("counter_price")
  counterMessage String?   @db.Text @map("counter_message")
  counterAt      DateTime? @map("counter_at")
  counterAccepted Boolean  @default(false) @map("counter_accepted")

  createdAt DateTime @default(now()) @map("created_at")

  // ── Relations ──
  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  freelancer User @relation(fields: [freelancerId], references: [id])

  @@unique([taskId, freelancerId])
  @@index([freelancerId])
  @@map("bids")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model ChatMessage {
  id String @id @default(cuid())
  taskId   String @map("task_id")
  senderId String @map("sender_id")

  content  String? @db.Text
  fileId   String? @map("file_id")
  fileType String? @map("file_type")  // "document" | "photo" | "video"
  fileName String? @map("file_name")

  // ── Reply, Edit, Delete (Stage 6: Chat & Notifications) ──
  replyToId String?       @map("reply_to_id")
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   ChatMessage[] @relation("MessageReplies")

  isEdited  Boolean   @default(false) @map("is_edited")
  editedAt  DateTime? @map("edited_at")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")

  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  // ── Relations ──
  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sender User @relation("SentMessages", fields: [senderId], references: [id])

  @@index([taskId])
  @@index([senderId])
  @@index([isRead])
  @@index([replyToId])
  @@map("chat_messages")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model Review {
  id String @id @default(cuid())
  taskId     String @map("task_id")
  fromUserId String @map("from_user_id")
  toUserId   String @map("to_user_id")

  rating  Int    // 1–5 (enforced in app layer)
  comment String @db.Text

  // Anti-fraud: only counts if IN_PROGRESS >= 24h
  isCountedInRating Boolean @default(false) @map("is_counted_in_rating")

  createdAt DateTime @default(now()) @map("created_at")

  // ── Relations ──
  task     Task @relation(fields: [taskId], references: [id])
  fromUser User @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  toUser   User @relation("ReviewsReceived", fields: [toUserId], references: [id])

  @@unique([taskId, fromUserId])
  @@index([toUserId])
  @@index([isCountedInRating])
  @@map("reviews")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model VipPayment {
  id String @id @default(cuid())
  userId String @map("user_id")

  amount           Int    // In so'm
  packageType      String @map("package_type") // "7_DAY" | "30_DAY"
  screenshotFileId String @map("screenshot_file_id")
  phoneNumber      String? @map("phone_number")

  isApproved     Boolean   @default(false) @map("is_approved")
  approvedBy     String?   @map("approved_by")
  approvedAt     DateTime? @map("approved_at")
  rejectedReason String?   @map("rejected_reason")

  createdAt DateTime @default(now()) @map("created_at")

  // ── Relations ──
  user User @relation(fields: [userId], references: [id])

  @@index([isApproved])
  @@index([userId])
  @@map("vip_payments")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model Dispute {
  id String @id @default(cuid())
  taskId         String           @unique @map("task_id")
  openedByUserId String           @map("opened_by_user_id")

  reason     String        @db.Text
  status     DisputeStatus @default(OPEN)
  adminNotes String?       @db.Text @map("admin_notes")
  resolvedBy String?       @map("resolved_by")
  resolvedAt DateTime?     @map("resolved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // ── Relations ──
  task Task @relation(fields: [taskId], references: [id])

  @@index([status])
  @@map("disputes")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model TransactionLog {
  id String @id @default(cuid())
  userId String @map("user_id")
  taskId String? @map("task_id")

  amount    Int               // Positive = credit, negative = debit
  type      TransactionType
  status    TransactionStatus @default(PENDING)
  reference String?           // External payment ref (Click/Payme)
  notes     String?

  createdAt DateTime @default(now()) @map("created_at")

  // ── Relations ──
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([taskId])
  @@index([status])
  @@map("transaction_logs")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model FraudLog {
  id String @id @default(cuid())
  suspectId String  @map("suspect_id")
  targetId  String? @map("target_id")

  type       String  // "FAKE_REVIEW" | "DUPLICATE_IP" | "SPAM_BID"
  details    Json    // Raw evidence
  isActioned Boolean @default(false) @map("is_actioned")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([suspectId])
  @@index([isActioned])
  @@map("fraud_logs")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model SavedTask {
  userId    String      @map("user_id")
  taskId    String      @map("task_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@id([userId, taskId])
  @@map("saved_tasks")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model Gig {
  id           String       @id @default(cuid())
  freelancerId String       @map("freelancer_id")
  category     TaskCategory @default(BOSHQA)
  title        String       @db.VarChar(200)
  description  String       @db.Text
  price        Int
  deliveryDays Int      @map("delivery_days")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  // в”Ђв”Ђ Relations в”Ђв”Ђ
  freelancer   User     @relation(fields: [freelancerId], references: [id])

  @@index([freelancerId])
  @@index([isActive])
  @@map("gigs")
}

// в”Ђв”Ђв”Ђ PORTFOLIO ITEM (Phase 15) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model PortfolioItem {
  id String @id @default(cuid())
  userId       String      @map("user_id")
  title        String   @db.VarChar(200)
  fileId       String   @map("file_id") // Telegram file_id
  createdAt    DateTime @default(now()) @map("created_at")

  // в”Ђв”Ђ Relations в”Ђв”Ђ
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portfolio_items")
}

// в”Ђв”Ђв”Ђ REPORT (v2.0) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model Report {
  id             String       @id @default(cuid())
  reporterId     String       @map("reporter_id")
  reportedId     String?      @map("reported_id")
  taskId         String?      @map("task_id")
  chatMsgId      String?      @map("chat_msg_id")
  reportType     ReportType   @map("report_type")
  reason         String       @db.Text
  evidenceFileId String?      @map("evidence_file_id")
  status         ReportStatus @default(PENDING)
  adminNotes     String?      @db.Text @map("admin_notes")
  resolvedById   String?      @map("resolved_by_id")
  resolvedAt     DateTime?    @map("resolved_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  reporter       User         @relation("ReporterRelation", fields: [reporterId], references: [id])
  reported       User?        @relation("ReportedRelation", fields: [reportedId], references: [id])
  task           Task?        @relation(fields: [taskId], references: [id])

  @@index([reporterId])
  @@index([reportedId])
  @@index([taskId])
  @@index([status])
  @@map("reports")
}

// в”Ђв”Ђв”Ђ ADMIN LOG (v2.0) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String   @map("admin_id")
  action    String
  details   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([adminId])
  @@map("admin_logs")
}

// в”Ђв”Ђв”Ђ SYSTEM SETTING (v2.0) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model SystemSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model VerificationRequest {
  id String @id @default(cuid())
  userId String @map("user_id")

  documentType    String  @map("document_type") // "PASSPORT" | "STUDENT_ID" | "DRIVER_LICENSE"
  documentFileId  String  @map("document_file_id")
  selfieFileId    String  @map("selfie_file_id")
  
  status         VerificationStatus @default(PENDING)
  adminNote      String? @db.Text @map("admin_note")
  resolvedAt     DateTime? @map("resolved_at")
  resolvedBy     String?   @map("resolved_by")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("verification_requests")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // "SYSTEM" | "TASK" | "MESSAGE" | "TRANSACTION" | "DISPUTE" | "BID"
  title     String
  message   String   @db.Text
  actionUrl String?  @map("action_url")
  status    String   @default("UNREAD") // UNREAD, READ
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("notifications")
}

// Phase 8: Peer Quality Shield Model
model TaskFlag {
  id        String   @id @default(cuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  reason    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_flags")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model WorkDelivery {
  id              String         @id @default(cuid())
  taskId          String         @unique @map("task_id")
  task            Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  freelancerId    String         @map("freelancer_id")
  
  // Protected preview — client sees this before accepting
  previewFileIds  String[]       @default([]) @map("preview_file_ids")
  previewNote     String?        @db.Text @map("preview_note")
  
  // Full delivery — revealed ONLY after client leaves review
  fullFileIds     String[]       @default([]) @map("full_file_ids")
  fullRevealedAt  DateTime?      @map("full_revealed_at")
  
  // Delivery metadata
  submittedAt     DateTime       @default(now()) @map("submitted_at")
  revisionCount   Int            @default(0) @map("revision_count")
  revisionHistory Json?          @map("revision_history") // Array of {note, requestedAt, by}
  
  // Status tracking
  clientViewedAt  DateTime?      @map("client_viewed_at")
  clientAcceptedAt DateTime?     @map("client_accepted_at")

  @@index([taskId])
  @@index([freelancerId])
  @@map("work_deliveries")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model LearningPath {
  id              String         @id @default(cuid())
  userId          String         @unique @map("user_id")
  
  // Data
  weakSkills      String[]       @default([]) @map("weak_skills")
  strongSkills    String[]       @default([]) @map("strong_skills")
  demandGaps      Json           @default("[]") @map("demand_gaps") // Array of categories/skills in high demand but low supply
  suggestedCourses Json          @default("[]") @map("suggested_courses") // Array of {title, url, description}
  
  // Timestamps
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@map("learning_paths")
}

// ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────

model TaskMilestone {
  id              String         @id @default(cuid())
  taskId          String         @map("task_id")
  task            Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  
  title           String
  isCompleted     Boolean        @default(false) @map("is_completed")
  order           Int            @default(0)
  
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([taskId])
  @@map("task_milestones")
}
