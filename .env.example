# ─── Runtime ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql://edumarket:strongpassword@localhost:5432/edumarket

# ─── Telegram ───────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_STORAGE_CHANNEL_ID=-100xxxxxxxxxx
TELEGRAM_WEBHOOK_SECRET=minimum_32_char_random_secret_string

# ─── JWT ────────────────────────────────────────
JWT_SECRET=minimum_32_character_random_string_here_keep_safe
JWT_EXPIRES_IN=7d

# ─── Admin ──────────────────────────────────────
# Comma-separated Telegram user IDs for admin access
ADMIN_TELEGRAM_IDS=123456789,987654321

# ─── CORS ───────────────────────────────────────
# Comma-separated allowed origins (add your deployed domain)
ALLOWED_ORIGINS=https://web.telegram.org,https://telegram.org,http://localhost:5173
